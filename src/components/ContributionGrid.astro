---
import type { Post } from "../lib/posts";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const byDate = new Map<string, number>();

for (const post of posts) {
  const key = post.data.pubDate.toISOString().slice(0, 10);
  byDate.set(key, (byDate.get(key) ?? 0) + Math.max(1, Math.ceil((post.data.wordCount ?? 1) / 800)));
}

const today = new Date();
const start = new Date(today);
start.setDate(today.getDate() - 364);
start.setDate(start.getDate() - start.getDay());

const days = Array.from({ length: 371 }, (_, index) => {
  const day = new Date(start);
  day.setDate(start.getDate() + index);
  const key = day.toISOString().slice(0, 10);
  const value = byDate.get(key) ?? 0;
  const level = value === 0 ? 0 : value < 2 ? 1 : value < 4 ? 2 : value < 8 ? 3 : 4;
  return { key, value, level };
});
---

<div class="contribution-wrap" aria-label="笔记贡献热力图">
  <div class="contribution-grid">
    {days.map((day) => (
      <span
        class={`heat level-${day.level}`}
        title={`${day.key}: ${day.value} note activity`}
        aria-label={`${day.key}: ${day.value} note activity`}
      />
    ))}
  </div>
  <div class="heat-legend">
    <span>Less</span>
    <span class="heat level-0"></span>
    <span class="heat level-1"></span>
    <span class="heat level-2"></span>
    <span class="heat level-3"></span>
    <span class="heat level-4"></span>
    <span>More</span>
  </div>
</div>
