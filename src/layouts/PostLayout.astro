---
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../lib/posts";

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  readingTime?: number;
  wordCount?: number;
  headings?: MarkdownHeading[];
}

const { title, description, pubDate, updatedDate, tags, readingTime, wordCount, headings = [] } =
  Astro.props;
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
---

<BaseLayout title={title} description={description}>
  <article class="post-shell">
    <header class="post-hero">
      <a class="back-link" href="../">← Notes</a>
      <div class="post-kicker">Embodied AI Note</div>
      <h1>{title}</h1>
      {description && <p>{description}</p>}
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {updatedDate && <span>Updated {formatDate(updatedDate)}</span>}
        {readingTime && <span>{readingTime} min read</span>}
        {wordCount && <span>{wordCount.toLocaleString("zh-CN")} words</span>}
      </div>
      <div class="tag-row">
        {tags.map((tag) => <a href={`../?tag=${encodeURIComponent(tag)}`}>#{tag}</a>)}
      </div>
    </header>

    <div class="post-grid">
      <div class="markdown-body">
        <slot />
      </div>
      {
        toc.length > 0 && (
          <aside class="toc" aria-label="文章目录">
            <div>目录</div>
            {toc.map((heading) => (
              <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            ))}
          </aside>
        )
      }
    </div>
  </article>

  <script>
    function mermaidTheme() {
      return document.documentElement.dataset.theme === "dark" ? "dark" : "neutral";
    }

    async function renderMermaid() {
      const blocks = document.querySelectorAll(".mermaid");
      if (!blocks.length) return;
      const { default: mermaid } = await import("mermaid");
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "loose",
        theme: mermaidTheme()
      });
      await mermaid.run({ nodes: Array.from(blocks) as HTMLElement[] });
    }

    renderMermaid();
  </script>
</BaseLayout>
